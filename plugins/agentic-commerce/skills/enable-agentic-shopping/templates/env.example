# --- Agentic checkout (MPP over Stripe SPT) ---------------------------------
# Merge these keys into the store's existing .env.example. Never overwrite real
# secrets — only add missing keys.

# Stripe live secret key. Test keys (sk_test_...) only work in dev; production
# agentic checkout requires a live key.
STRIPE_SECRET_KEY=sk_live_...

# Stripe profile id for Shared Payment Tokens (the SPT "network"). Live, not test.
STRIPE_PROFILE_ID=profile_...

# SPT-backed payment methods to advertise (CSV). Default: card,link
STRIPE_PAYMENT_METHOD_TYPES=card,link

# HMAC secret that binds MPP payment challenges to orders (replay protection).
# Generate with: openssl rand -base64 32
MPP_SECRET_KEY=

# Currency for quotes/charges. Default: usd
CURRENCY=usd

# Public URL agents see in discovery docs (so manifests never advertise localhost).
# On Vercel, VERCEL_URL is used automatically if this is unset.
STORE_URL=
# NEXT_PUBLIC_STORE_URL=    # use this name on Next.js if you prefer
